# CodeSip Frontend Environment Configuration Template
# Duplicate this file to '.env' (for development) or '.env.production' (for deployment)

# 1. API Configuration
VITE_API_URL=https://codesip-main.onrender.com/api

# 2. Search Engine Optimization & Crawlers
# Google Search Console HTML Meta verification tag
# Find this in your Google Search Console under settings > verification > HTML tag method
# It will generate a code, e.g., "google-site-verification=xxxxxx" (put the exact content string here)
VITE_GOOGLE_SITE_VERIFICATION=your_google_site_verification_code_here

# 3. Google Analytics Tracking
# Paste your GA4 Measurement ID here, e.g., "G-XXXXXXXXXX"
# Find this in your GA Admin panel under Data Streams > Stream Details
VITE_GA_TRACKING_ID=
